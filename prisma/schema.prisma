generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  username  String
  role      Role     @default(PARENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id])
}

model School {
  id        String    @id @default(cuid())
  name      String
  ownerId   String?   @unique
  createdAt DateTime  @default(now())
  invoices  Invoice[]
  users     User[]
}

model Invoice {
  id          String        @id @default(cuid())
  schoolId    String
  parentId    String?
  studentId   String?
  amount      Float
  status      InvoiceStatus @default(PENDING)
  dueDate     DateTime
  paidAt      DateTime?
  description String?
  createdAt   DateTime      @default(now())
  school      School        @relation(fields: [schoolId], references: [id])
}

enum Role {
  SUPER_ADMIN
  SCHOOL_OWNER
  TEACHER
  PARENT
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}
